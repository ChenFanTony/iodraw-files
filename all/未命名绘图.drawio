        <mxCell id="fCMbRvaDpKP1Wld_WHLn-45" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="1. conntroller： 检查元数据wait_status， 查询副本还在, 就会直接调度到原单节点（好的副本）" vertex="1">
          <mxGeometry height="40" width="220" x="285" y="690" as="geometry" />
        </mxCell>
        <mxCell id="fCMbRvaDpKP1Wld_WHLn-46" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="2. controller： 按旧的节点调度发送连接connect 请求让节点初始化副本" vertex="1">
